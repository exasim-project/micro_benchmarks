FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    p
    {
        solver          PCG;
        preconditioner  diagonal;
        tolerance       0;
        relTol          1e-2;
    }
    pFinal
    {
        $p;
    }
    Phi
    {
        $p;
    }
    U
    {
        solver          PBiCGStab;
        preconditioner  diagonal;
        tolerance       0;
        relTol          0.1;
    }
    UFinal
    {
        solver          PBiCGStab;
        preconditioner  diagonal;
        tolerance       0;
        relTol          0.1;
    }
    nuTilda
    {
        solver          PBiCGStab;
        preconditioner  diagonal;
        tolerance       0;
        relTol          0.1;
    }
}

PISO
{
    momentumPredictor   yes;
    nCorrectors     4;
    nNonOrthogonalCorrectors 0;
//    pRefCell        0;
//    pRefValue       0;
}


// ************************************************************************* //
